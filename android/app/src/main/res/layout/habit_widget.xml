<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/habit_widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Habit Flow"
                android:textColor="#FFF7E8"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="No habits yet"
                android:textColor="#CCEFF2FF"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_open_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/habit_widget_open_chip"
            android:paddingLeft="10dp"
            android:paddingTop="6dp"
            android:paddingRight="10dp"
            android:paddingBottom="6dp"
            android:text="Open"
            android:textColor="#FFF4F6FF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/widget_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@drawable/habit_widget_empty_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No habits to show"
            android:textColor="#FFF7E8"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_empty_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Create a habit to start your streak."
            android:textColor="#CCEAF0FF"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_rows"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/habit_row_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/habit_widget_row_background"
            android:gravity="center_vertical"
            android:minHeight="52dp"
            android:orientation="horizontal"
            android:paddingLeft="10dp"
            android:paddingTop="8dp"
            android:paddingRight="10dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/habit_row_0_accent"
                android:layout_width="4dp"
                android:layout_height="36dp"
                android:background="#6D7CFF"
                android:text="" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/habit_row_0_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Read"
                    android:textColor="#FFF7E8"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/habit_row_0_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="6dp"
                    android:max="4"
                    android:progress="1"
                    android:progressTint="#AAB7FF"
                    android:progressBackgroundTint="#33FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/habit_row_0_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="@drawable/habit_widget_count_chip"
                android:paddingLeft="8dp"
                android:paddingTop="5dp"
                android:paddingRight="8dp"
                android:paddingBottom="5dp"
                android:text="1/4"
                android:textColor="#FFF7E8"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habit_row_0_minus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/habit_widget_action_button"
                android:gravity="center"
                android:text="-"
                android:textColor="#FFF7E8"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habit_row_0_plus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginLeft="6dp"
                android:background="@drawable/habit_widget_action_button_strong"
                android:gravity="center"
                android:text="+"
                android:textColor="#FF16203B"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/habit_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/habit_widget_row_background"
            android:gravity="center_vertical"
            android:minHeight="52dp"
            android:orientation="horizontal"
            android:paddingLeft="10dp"
            android:paddingTop="8dp"
            android:paddingRight="10dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/habit_row_1_accent"
                android:layout_width="4dp"
                android:layout_height="36dp"
                android:background="#6D7CFF"
                android:text="" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/habit_row_1_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Move"
                    android:textColor="#FFF7E8"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/habit_row_1_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="6dp"
                    android:max="4"
                    android:progress="1"
                    android:progressTint="#AAB7FF"
                    android:progressBackgroundTint="#33FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/habit_row_1_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="@drawable/habit_widget_count_chip"
                android:paddingLeft="8dp"
                android:paddingTop="5dp"
                android:paddingRight="8dp"
                android:paddingBottom="5dp"
                android:text="0/1"
                android:textColor="#FFF7E8"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habit_row_1_minus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/habit_widget_action_button"
                android:gravity="center"
                android:text="-"
                android:textColor="#FFF7E8"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habit_row_1_plus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginLeft="6dp"
                android:background="@drawable/habit_widget_action_button_strong"
                android:gravity="center"
                android:text="+"
                android:textColor="#FF16203B"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/habit_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/habit_widget_row_background"
            android:gravity="center_vertical"
            android:minHeight="52dp"
            android:orientation="horizontal"
            android:paddingLeft="10dp"
            android:paddingTop="8dp"
            android:paddingRight="10dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/habit_row_2_accent"
                android:layout_width="4dp"
                android:layout_height="36dp"
                android:background="#6D7CFF"
                android:text="" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/habit_row_2_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Plan"
                    android:textColor="#FFF7E8"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/habit_row_2_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="6dp"
                    android:max="4"
                    android:progress="1"
                    android:progressTint="#AAB7FF"
                    android:progressBackgroundTint="#33FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/habit_row_2_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="@drawable/habit_widget_count_chip"
                android:paddingLeft="8dp"
                android:paddingTop="5dp"
                android:paddingRight="8dp"
                android:paddingBottom="5dp"
                android:text="0/2"
                android:textColor="#FFF7E8"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habit_row_2_minus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/habit_widget_action_button"
                android:gravity="center"
                android:text="-"
                android:textColor="#FFF7E8"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habit_row_2_plus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginLeft="6dp"
                android:background="@drawable/habit_widget_action_button_strong"
                android:gravity="center"
                android:text="+"
                android:textColor="#FF16203B"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
